APP_NAME="PowerMail Core"
NODE_ENV=development

NODE_API_PORT=4000
NODE_PUBLIC_BASE_URL=http://127.0.0.1:4000
REACT_WEB_ORIGIN=http://127.0.0.1:5174
# Leave empty when the API and frontend use the same domain (recommended).
VITE_API_BASE_URL=

# Use separate, random production secrets. Existing installations may keep the
# previous APP_KEY value as NODE_ENCRYPTION_KEY to read stored SMTP/IMAP secrets.
NODE_AUTH_SECRET=replace-with-a-long-random-auth-secret
NODE_ENCRYPTION_KEY=base64:replace-with-a-base64-encoded-32-byte-key

# Optional one-time administrator bootstrap. Keep these in Railway Variables,
# not in Git. Existing administrators are left unchanged on later restarts.
ADMIN_NAME="PowerMail Admin"
ADMIN_EMAIL=
ADMIN_PASSWORD=

DB_CONNECTION=sqlite
# On Railway, attach a volume (for example at /data); the app automatically
# stores database.sqlite at RAILWAY_VOLUME_MOUNT_PATH. DB_DATABASE is optional.
DB_DATABASE=database/database.sqlite

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
