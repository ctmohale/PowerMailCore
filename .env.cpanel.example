APP_NAME="PowerMail Core"
NODE_ENV=production

NODE_API_PORT=4000
NODE_PUBLIC_BASE_URL=https://mailcore.yourdomain.co.za
REACT_WEB_ORIGIN=https://mailcore.yourdomain.co.za
VITE_API_BASE_URL=https://mailcore.yourdomain.co.za/api

NODE_AUTH_SECRET=replace-with-a-long-random-auth-secret
NODE_ENCRYPTION_KEY=base64:replace-with-a-base64-encoded-32-byte-key

DB_CONNECTION=sqlite
DB_DATABASE=/home/CPANEL_USER/powermail-core/database/database.sqlite

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
